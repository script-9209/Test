-- Function to manage Billboard Tag (Murderer/Sheriff only)
local function manageTag(char, text, color, visible)
    local head = char:FindFirstChild("Head")
    if not head then return end
    
    local tag = head:FindFirstChild("ExodusTag")
    if visible then
        if not tag then
            local bill = Instance.new("BillboardGui", head)
            bill.Name = "ExodusTag"
            bill.Size = UDim2.new(0, 100, 0, 50)
            bill.StudsOffset = Vector3.new(0, 2, 0)
            bill.AlwaysOnTop = true

            local label = Instance.new("TextLabel", bill)
            label.Name = "RoleLabel"
            label.BackgroundTransparency = 1
            label.Size = UDim2.new(1, 0, 1, 0)
            label.Font = Enum.Font.GothamBold
            label.TextSize = 12
            label.TextStrokeTransparency = 0
            tag = bill
        end
        tag.RoleLabel.Text = text
        tag.RoleLabel.TextColor3 = color
    else
        if tag then tag:Destroy() end
    end
end

-- SMOOTH HIGHLIGHT LOGIC (Fixes Blinking)
local function updateESP()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character then
            local char = v.Character
            local highlight = char:FindFirstChild("ExodusHighlight")
            
            if ESPEnabled then
                if not highlight then
                    highlight = Instance.new("Highlight", char)
                    highlight.Name = "ExodusHighlight"
                    highlight.OutlineTransparency = 0
                    highlight.FillTransparency = 0.5
                end

                -- Determine Role
                local hasKnife = v.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")
                local hasGun = v.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")

                if hasKnife then
                    highlight.FillColor = Color3.fromRGB(255, 0, 0)
                    highlight.Enabled = true
                    manageTag(char, "MURDERER", Color3.fromRGB(255, 0, 0), true)
                elseif hasGun then
                    highlight.FillColor = Color3.fromRGB(0, 0, 255)
                    highlight.Enabled = true
                    manageTag(char, "SHERIFF", Color3.fromRGB(0, 0, 255), true)
                else
                    highlight.FillColor = Color3.fromRGB(0, 255, 0) -- Innocent
                    highlight.Enabled = true
                    manageTag(char, "", nil, false) -- Remove text for innocents
                end
            else
                if highlight then highlight:Destroy() end
                manageTag(char, "", nil, false)
            end
        end
    end
end

-- Shooting Logic
local function getMurderer()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            if v.Character:FindFirstChild("Knife") or v.Backpack:FindFirstChild("Knife") then
                return v.Character.HumanoidRootPart
            end
        end
    end
    return nil
end

local function fireGun()
    local char = lp.Character
    local gun = char and char:FindFirstChild("Gun")
    
    if gun and gun:FindFirstChild("Shoot") then
        local murdererHRP = getMurderer()
        local origin = Camera.CFrame
        local targetCFrame = murdererHRP and CFrame.new(origin.Position, murdererHRP.Position) or origin
        
        local args = {
            [1] = targetCFrame,
            [2] = murdererHRP and CFrame.new(murdererHRP.Position) or (origin * CFrame.new(0, 0, -500))
        }
        gun.Shoot:FireServer(unpack(args))
    end
end

-- Draggable Button Logic
local dragging, dragStart, startPos
ShootButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        fireGun()
        if not ButtonLocked then
            dragging = true
            dragStart = input.Position
            startPos = ShootButton.Position
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        ShootButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

