local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local Window = Rayfield:CreateWindow({
   Name = "MM2 Gemini | 2026 OMNI",
   LoadingTitle = "Configuring Attack Delays...",
   ConfigurationSaving = {Enabled = true, FolderName = "MM2_Omni"}
})

-- Variables
local autoSlashEnabled = false
local slashRange = 12
local slashCooldown = 0.5 -- Default (Adjustable 0.1s to 1.0s)
local lastSlash = 0

local MurdererHighlight = Instance.new("Highlight")
MurdererHighlight.FillColor = Color3.fromRGB(255, 0, 0)

-- Helper: Get Murderer
local function GetMurderer()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            if p.Character:FindFirstChild("Knife") or p.Backpack:FindFirstChild("Knife") then
                return p
            end
        end
    end
    return nil
end

-- Logic: Precision Kill Aura
local function DoCombatLogic()
    local knife = LocalPlayer.Character:FindFirstChild("Knife")
    if not knife or not autoSlashEnabled then return end

    -- Check if cooldown has passed
    if tick() - lastSlash >= slashCooldown then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                
                if dist <= slashRange then 
                    knife:Activate()
                    lastSlash = tick()
                    
                    -- Optional: Speed up the visual animation to match the speed
                    local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                    if hum then
                        for _, anim in pairs(hum:GetPlayingAnimationTracks()) do
                            if anim.Name:lower():find("attack") or anim.Name:lower():find("slash") then
                                anim:AdjustSpeed(2) -- Makes the arm move faster
                            end
                        end
                    end
                    break -- Only hit one person per interval to prevent lag
                end
            end
        end
    end
end

-- TABS
local CombatTab = Window:CreateTab("Combat", 4483362458)
local UtilityTab = Window:CreateTab("Utility", 4483362458)

--- COMBAT TAB ---

CombatTab:CreateToggle({
    Name = "Auto Slash (Kill Aura)",
    CurrentValue = false,
    Callback = function(V) autoSlashEnabled = V end
})

CombatTab:CreateInput({
   Name = "Slash Speed (Seconds)",
   PlaceholderText = "Min 0.1, Max 1.0",
   Callback = function(Text)
      local num = tonumber(Text)
      if num then
         -- Clamp the value between 0.1 and 1.0
         slashCooldown = math.clamp(num, 0.1, 1.0)
         Rayfield:Notify({
            Title = "Speed Updated", 
            Content = "Interval set to: " .. tostring(slashCooldown) .. "s", 
            Duration = 2
         })
      end
   end,
})

CombatTab:CreateInput({
   Name = "Slash Range (Studs)",
   PlaceholderText = "12",
   Callback = function(Text)
      if tonumber(Text) then slashRange = tonumber(Text) end
   end,
})

--- UTILITY TAB ---

UtilityTab:CreateToggle({
   Name = "Murderer ESP",
   CurrentValue = false,
   Callback = function(V) espEnabled = V; if not V then MurdererHighlight.Parent = nil end end,
})

UtilityTab:CreateButton({
    Name = "TP to Dropped Gun",
    Callback = function()
        local gd = workspace:FindFirstChild("GunDrop") or workspace:FindFirstChild("Gun")
        if gd then LocalPlayer.Character.HumanoidRootPart.CFrame = gd.CFrame end
    end
})

-- Main Loop
RunService.Heartbeat:Connect(function()
    DoCombatLogic()
    if espEnabled then
        local m = GetMurderer()
        MurdererHighlight.Parent = (m and m.Character) and m.Character or nil
    end
end)
