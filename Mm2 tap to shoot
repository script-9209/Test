-- Global Loops (ESP & Auto-Grab)
RunService.RenderStepped:Connect(function()
    if espEnabled then
        local m = GetMurderer()
        MurdererHighlight.Parent = (m and m.Character) and m.Character or nil
    end
    
    if autoGrabEnabled then
        GrabDroppedGun()
    end
end)
