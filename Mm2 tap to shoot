local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local Window = Rayfield:CreateWindow({
   Name = "MM2 Gemini | 2026 OMNI",
   LoadingTitle = "Securing UI Elements...",
   ConfigurationSaving = {Enabled = false}
})

-- State
local buttonLocked = false -- The UI Lock variable
local autoSlash = false
local slashRange = 12
local lastSlash = 0
local espEnabled = false
local MurdererHighlight = Instance.new("Highlight")
MurdererHighlight.FillColor = Color3.fromRGB(255, 0, 0)

-- Logic: Get Murderer
local function GetMurderer()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            if p.Character:FindFirstChild("Knife") or p.Backpack:FindFirstChild("Knife") then
                return p
            end
        end
    end
    return nil
end

-- Logic: Silent Shoot HRP
local function SilentShoot()
    local murderer = GetMurderer()
    local gun = LocalPlayer.Character:FindFirstChild("Gun") or LocalPlayer.Backpack:FindFirstChild("Gun")
    
    if murderer and gun then
        if gun.Parent == LocalPlayer.Backpack then
            LocalPlayer.Character.Humanoid:EquipTool(gun)
            task.wait(0.4) 
        end
        
        local targetPos = murderer.Character.HumanoidRootPart.Position
        local shootRemote = gun:FindFirstChild("ShootGun") or game:GetService("ReplicatedStorage"):FindFirstChild("ShootGun")
        
        if shootRemote then
            shootRemote:FireServer(targetPos, LocalPlayer.Character.HumanoidRootPart.Position)
        else
            gun:Activate()
        end
    end
end

-- Tabs
local Main = Window:CreateTab("Main", 4483362458)

Main:CreateToggle({
   Name = "Show 'Tap to Shoot' Button",
   CurrentValue = false,
   Callback = function(Value)
      if Value then
         if not _G.FinalBtnUI then
            local sg = Instance.new("ScreenGui", game.CoreGui)
            local b = Instance.new("TextButton", sg)
            _G.FinalBtnUI = sg
            b.Size = UDim2.new(0, 140, 0, 50)
            b.Position = UDim2.new(0.5, -70, 0.7, 0)
            b.Text = "TAP TO SHOOT"
            b.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            b.TextColor3 = Color3.fromRGB(255, 255, 255)
            b.Font = Enum.Font.GothamBold
            Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
            local st = Instance.new("UIStroke", b)
            st.Color = Color3.fromRGB(255, 0, 0)
            st.Thickness = 2
            
            -- Draggable Logic with Lock Check
            local drag, start, startPos
            b.InputBegan:Connect(function(i) 
                if not buttonLocked and (i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch) then 
                    drag = true 
                    start = i.Position 
                    startPos = b.Position 
                end 
            end)

            UserInputService.InputChanged:Connect(function(i) 
                if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then 
                    local d = i.Position - start 
                    b.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y) 
                end 
            end)

            UserInputService.InputEnded:Connect(function(i) 
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then 
                    drag = false 
                end 
            end)
            
            b.MouseButton1Click:Connect(SilentShoot)
         end
         _G.FinalBtnUI.Enabled = true
      else
         if _G.FinalBtnUI then _G.FinalBtnUI.Enabled = false end
      end
   end
})

Main:CreateToggle({
    Name = "Lock Button Position",
    CurrentValue = false,
    Callback = function(V) 
        buttonLocked = V 
        Rayfield:Notify({
            Title = "UI Update", 
            Content = V and "Button Locked" or "Button Unlocked (Draggable)", 
            Duration = 2
        })
    end
})

Main:CreateToggle({
   Name = "Murderer ESP",
   CurrentValue = false,
   Callback = function(v) espEnabled = v; if not v then MurdererHighlight.Parent = nil end end
})

-- Global Heartbeat Loop
RunService.Heartbeat:Connect(function()
    if espEnabled then
        local m = GetMurderer()
        MurdererHighlight.Parent = (m and m.Character) and m.Character or nil
    end
    
    if autoSlash and tick() - lastSlash >= 0.5 then
        local k = LocalPlayer.Character:FindFirstChild("Knife")
        if k then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    if (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude <= slashRange then
                        k:Activate()
                        lastSlash = tick()
                        break
                    end
                end
            end
        end
    end
end)
