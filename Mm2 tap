--- UTILITY ---
local function getMurderer()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and (v.Character:FindFirstChild("Knife") or v.Backpack:FindFirstChild("Knife")) then return v end
    end
    return nil
end

--- COMBAT FUNCTIONS (ORIGIN & 2ND ARG TARGETED) ---
local function fireGun()
    local gun = lp.Character:FindFirstChild("Gun") or lp.Backpack:FindFirstChild("Gun")
    local m = getMurderer()
    if gun and m and m.Character:FindFirstChild("HumanoidRootPart") then
        if gun.Parent == lp.Backpack then lp.Character.Humanoid:EquipTool(gun) task.wait(0.1) end
        
        local murdHRP = m.Character.HumanoidRootPart
        local args = {
            [1] = CFrame.new(murdHRP.Position, murdHRP.Position) * CFrame.Angles(1.4531978368759155, 0.04432811588048935, 1.6501713991165161), 
            [2] = murdHRP.Position -- Target Position as 2nd Argument
        }
        if gun:FindFirstChild("Shoot") then gun.Shoot:FireServer(unpack(args)) end
    end
end

local function throwAction()
    local knife = lp.Character:FindFirstChild("Knife") or lp.Backpack:FindFirstChild("Knife")
    local m = getMurderer()
    if knife and m and m.Character:FindFirstChild("HumanoidRootPart") then
        if knife.Parent == lp.Backpack then lp.Character.Humanoid:EquipTool(knife) end
        
        local murdHRP = m.Character.HumanoidRootPart
        local args = {
            [1] = CFrame.new(murdHRP.Position, murdHRP.Position) * CFrame.Angles(1.4531978368759155, 0.04432811588048935, 1.6501713991165161), 
            [2] = murdHRP.Position -- Target Position as 2nd Argument
        }
        knife.Events.KnifeThrown:FireServer(unpack(args))
    end
end

--- AUTO COINS (1.5s) ---
task.spawn(function()
    while true do
        task.wait()
        if _G.AutoCoins and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            local coins = workspace:FindFirstChild("CoinContainer", true) or workspace:FindFirstChild("Coins", true)
            if coins then
                for _, c in pairs(coins:GetChildren()) do
                    if not _G.AutoCoins then break end
                    lp.Character.HumanoidRootPart.CFrame = c.CFrame
                    task.wait(1.5)
                end
            end
        end
    end
end)

--- DRAGGABLE UI ---
local function makeDraggable(btn, lockKey, customAction)
    local dragging, dragStart, startPos
    btn.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            if customAction then customAction() end
            if not _G.LockAll then dragging = true dragStart = input.Position startPos = btn.Position end
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function() dragging = false end)
end

makeDraggable(ShootBtn, "ShootLocked", fireGun)
makeDraggable(GunBtn, "GunLocked", function()
    local d = workspace:FindFirstChild("GunDrop", true)
    if d and lp.Character:FindFirstChild("HumanoidRootPart") then
        local old = lp.Character.HumanoidRootPart.CFrame
        lp.Character.HumanoidRootPart.CFrame = d.CFrame
        task.wait(0.1)
        lp.Character.HumanoidRootPart.CFrame = old
    end
end)
makeDraggable(ThrowBtn, "ThrowLocked", throwAction)

--- ESP SYSTEM ---
local function applyESP(p, char)
    if p == lp or not char then return end
    local highlight = char:FindFirstChild("ExodusHighlight") or Instance.new("Highlight", char)
    highlight.Name = "ExodusHighlight"; highlight.FillTransparency = 0.5
    local head = char:WaitForChild("Head", 5)
    local bill = head:FindFirstChild("ExodusBill") or Instance.new("BillboardGui", head)
    bill.Name = "ExodusBill"; bill.Size = UDim2.new(0, 100, 0, 50); bill.AlwaysOnTop = true; bill.ExtentsOffset = Vector3.new(0, 3, 0)
    local label = bill:FindFirstChild("ExodusLabel") or Instance.new("TextLabel", bill)
    label.Name = "ExodusLabel"; label.Size = UDim2.new(1, 0, 1, 0); label.BackgroundTransparency = 1; label.Font = "GothamBold"; label.TextSize = 14

    task.spawn(function()
        while char and char.Parent do
            if _G.ESPEnabled then
                local isM = p.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")
                local isS = p.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")
                highlight.Enabled = true
                if isM then
                    bill.Enabled = true; highlight.FillColor = Color3.new(1, 0, 0); label.Text = "MURDERER"; label.TextColor3 = Color3.new(1, 0, 0)
                elseif isS then
                    bill.Enabled = true; highlight.FillColor = Color3.new(0, 0, 1); label.Text = "SHERIFF"; label.TextColor3 = Color3.new(0, 0, 1)
                else
                    bill.Enabled = false; highlight.FillColor = Color3.new(0, 1, 0)
                end
            else
                highlight.Enabled = false; bill.Enabled = false
            end
            task.wait(1)
        end
    end)
end

for _, p in pairs(Players:GetPlayers()) do
    if p.Character then applyESP(p, p.Character) end
    p.CharacterAdded:Connect(function(c) applyESP(p, c) end)
end

