-- RGB Logic
local function syncRGB(stroke)
    task.spawn(function()
        while true do
            local hue = tick() % 5 / 5
            stroke.Color = Color3.fromHSV(hue, 1, 1)
            task.wait()
        end
    end)
end

-- Floating Button Factory
local function createBaseButton(name, text, pos, isCircle, isRect)
    local btn = Instance.new("TextButton", ScreenGui)
    btn.Name = name
    btn.Visible = false
    if isRect then btn.Size = UDim2.new(0, 140, 0, 60) else btn.Size = UDim2.new(0, 80, 0, 80) end
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    btn.BackgroundTransparency = 0.5 
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 18
    btn.ZIndex = 10
    local corner = Instance.new("UICorner", btn)
    corner.CornerRadius = isCircle and UDim.new(1, 0) or UDim.new(0, 12)
    local stroke = Instance.new("UIStroke", btn)
    stroke.Thickness = 2.5
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    syncRGB(stroke)
    return btn, stroke
end

