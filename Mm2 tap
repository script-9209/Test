local function createBaseButton(name, text, pos, isCircle)
    local btn = Instance.new("TextButton", ScreenGui)
    btn.Name = name; btn.Visible = false; btn.Size = UDim2.new(0, 90, 0, 90); btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25); btn.BackgroundTransparency = 0.7 
    btn.Text = text; btn.TextColor3 = Color3.fromRGB(255, 255, 255); btn.Font = Enum.Font.GothamBold; btn.TextSize = 16; btn.ZIndex = 10
    local corner = Instance.new("UICorner", btn); corner.CornerRadius = isCircle and UDim.new(1, 0) or UDim.new(0, 18)
    local stroke = Instance.new("UIStroke", btn); stroke.Thickness = 2; stroke.Color = Color3.fromRGB(60, 60, 60)
    return btn, stroke
end

