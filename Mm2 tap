--- LOGIC FUNCTIONS ---

local function getMurdererHRP()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and (v.Character:FindFirstChild("Knife") or v.Backpack:FindFirstChild("Knife")) then
            return v.Character:FindFirstChild("HumanoidRootPart")
        end
    end
    return nil
end

local function fireGun()
    local char = lp.Character
    local gun = (char and char:FindFirstChild("Gun")) or (lp.Backpack:FindFirstChild("Gun"))
    if gun then
        if gun.Parent == lp.Backpack then 
            lp.Character.Humanoid:EquipTool(gun) 
            task.wait(0.1) 
        end
        local targetHRP = getMurdererHRP()
        local origin = Camera.CFrame
        local targetPos
        
        if targetHRP then
            targetPos = targetHRP.Position + (targetHRP.Velocity * PredictionIntensity)
        else
            targetPos = origin.Position + (origin.LookVector * 500)
        end
        
        if gun:FindFirstChild("Shoot") then
            gun.Shoot:FireServer(CFrame.new(origin.Position, targetPos), CFrame.new(targetPos))
        end
    end
end

local function tpToGun()
    local drop = workspace:FindFirstChild("GunDrop", true)
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if drop and hrp then
        local oldPos = hrp.CFrame
        hrp.CFrame = drop.CFrame
        task.wait(0.1)
        hrp.CFrame = oldPos
    end
end

-- Draggable Logic
local function makeDraggable(btn, lockKey)
    local dragging, dragStart, startPos
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if btn == GunButton then tpToGun() else fireGun() end
            if not _G[lockKey] then dragging = true dragStart = input.Position startPos = btn.Position end
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input) dragging = false end)
end

