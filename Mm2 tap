--- PERSISTENT ESP (Fix for all players) ---
local function getRole(p)
    local char = p.Character
    if not char then return "Innocent" end
    if p.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife") then return "Murderer" end
    if p.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun") then return "Sheriff" end
    return "Innocent"
end

task.spawn(function()
    while true do
        if _G.ESPEnabled then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= lp and p.Character and p.Character:FindFirstChild("Head") then
                    local char = p.Character
                    local role = getRole(p)
                    
                    -- Highlight Logic
                    local high = char:FindFirstChild("ExodusHigh") or Instance.new("Highlight", char)
                    high.Name = "ExodusHigh"; high.OutlineTransparency = 0; high.FillTransparency = 0.5
                    
                    -- Billboard Logic
                    local head = char.Head
                    local bill = head:FindFirstChild("ExodusBill") or Instance.new("BillboardGui", head)
                    bill.Name = "ExodusBill"; bill.Size = UDim2.new(0, 100, 0, 50); bill.AlwaysOnTop = true; bill.ExtentsOffset = Vector3.new(0, 3, 0)
                    local lab = bill:FindFirstChild("ExodusLabel") or Instance.new("TextLabel", bill)
                    lab.Name = "ExodusLabel"; lab.Size = UDim2.new(1, 0, 1, 0); lab.BackgroundTransparency = 1; lab.Font = Enum.Font.GothamBold; lab.TextSize = 14
                    
                    if role == "Murderer" then
                        high.FillColor = Color3.new(1, 0, 0); lab.Text = "MURDERER"; lab.TextColor3 = Color3.new(1, 0, 0); bill.Enabled = true
                    elseif role == "Sheriff" then
                        high.FillColor = Color3.new(0, 0, 1); lab.Text = "SHERIFF"; lab.TextColor3 = Color3.new(0, 0, 1); bill.Enabled = true
                    else
                        high.FillColor = Color3.new(0, 1, 0); bill.Enabled = false -- No billboard for Innocents
                    end
                    high.Enabled = true
                end
            end
        else
            for _, p in pairs(Players:GetPlayers()) do
                if p.Character then
                    if p.Character:FindFirstChild("ExodusHigh") then p.Character.ExodusHigh.Enabled = false end
                    if p.Character:FindFirstChild("Head") and p.Character.Head:FindFirstChild("ExodusBill") then p.Character.Head.ExodusBill.Enabled = false end
                end
            end
        end
        task.wait(1)
    end
end)

--- VIOLENT FLING & SAFE RETURN ---
local function ultraFling(target)
    if lp.Character and target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = lp.Character.HumanoidRootPart
        local hum = lp.Character.Humanoid
        local targetHrp = target.Character.HumanoidRootPart
        local oldCF = hrp.CFrame
        
        local bA = Instance.new("BodyAngularVelocity", hrp)
        bA.AngularVelocity = Vector3.new(500000, 500000, 500000) -- Maximum Violence
        bA.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        hum.PlatformStand = true 

        local strike = RunService.Heartbeat:Connect(function()
            if hrp and targetHrp and targetHrp.Parent then
                hrp.Velocity = Vector3.new(2500, 2500, 2500)
                hrp.CFrame = targetHrp.CFrame * CFrame.new(0, -0.5, 0)
            end
        end)

        task.wait(0.6)
        strike:Disconnect(); bA:Destroy()
        
        -- SAFE RETURN (Hard Anchor)
        hrp.Anchored = true
        hrp.CFrame = oldCF + Vector3.new(0, 5, 0)
        for i = 1, 15 do
            hrp.Velocity = Vector3.zero; hrp.RotVelocity = Vector3.zero
            RunService.Heartbeat:Wait()
        end
        hrp.Anchored = false
        hum.PlatformStand = false
    end
end

