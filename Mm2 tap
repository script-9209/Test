end)

--- REFINED ESP SYSTEM ---
local function setupESP(p)
    local function create(char)
        if p == lp then return end
        local head = char:WaitForChild("Head", 15)
        if not head then return end
        
        local h = Instance.new("Highlight", char)
        h.Name = "ExodusHighlight"
        local b = Instance.new("BillboardGui", head)
        b.Name = "ExodusTag"
        b.Size = UDim2.new(0, 100, 0, 50); b.AlwaysOnTop = true
        local l = Instance.new("TextLabel", b)
        l.BackgroundTransparency = 1; l.Size = UDim2.new(1, 0, 1, 0); l.Font = Enum.Font.GothamBold; l.TextSize = 14
        
        task.spawn(function()
            while char.Parent and ESPEnabled do
                local hasK = p.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")
                local hasG = p.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")
                
                h.FillColor = hasK and Color3.new(1,0,0) or (hasG and Color3.new(0,0,1) or Color3.new(0,1,0))
                
                -- Remove Innocent Billboard label, only show for roles
                if hasK then
                    l.Text = "MURDERER"; l.TextColor3 = Color3.new(1,0,0)
                elseif hasG then
                    l.Text = "SHERIFF"; l.TextColor3 = Color3.new(0,0,1)
                else
                    l.Text = "" -- Innocent Billboard removed
                end
                task.wait(1)
            end
            h:Destroy(); b:Destroy()
        end)
    end
    p.CharacterAdded:Connect(create)
    if p.Character then create(p.Character) end
end

Players.PlayerAdded:Connect(setupESP)
for _, p in pairs(Players:GetPlayers()) do setupESP(p) end

