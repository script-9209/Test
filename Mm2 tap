--- COMBAT REMOTES ---
local function throwAction()
    local char = lp.Character
    local knife = char:FindFirstChild("Knife") or lp.Backpack:FindFirstChild("Knife")
    local m = nil; local dist = math.huge
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local d = (char.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d; m = v end
        end
    end
    if knife and m then
        if knife.Parent == lp.Backpack then char.Humanoid:EquipTool(knife) task.wait(0.1) end
        local tPos = m.Character.HumanoidRootPart.Position
        local args = {
            [1] = CFrame.new(tPos, tPos) * CFrame.Angles(1.45, 0.04, 1.65),
            [2] = CFrame.new(tPos)
        }
        knife.Events.KnifeThrown:FireServer(unpack(args))
    end
end

local function fireGun()
    local char = lp.Character
    local gun = char:FindFirstChild("Gun") or lp.Backpack:FindFirstChild("Gun")
    local m = nil; for _, v in pairs(Players:GetPlayers()) do if getRole(v) == "Murderer" then m = v break end end
    if gun and m and m.Character:FindFirstChild("HumanoidRootPart") then
        if gun.Parent == lp.Backpack then char.Humanoid:EquipTool(gun) task.wait(0.1) end
        local tHRP = m.Character.HumanoidRootPart
        local args = {[1] = CFrame.new(tHRP.Position, tHRP.Position) * CFrame.Angles(1.45, 0, 1.6), [2] = tHRP.Position}
        if gun:FindFirstChild("Shoot") then gun.Shoot:FireServer(unpack(args)) end
    end
end

--- HUD DRAGGABLE ---
local function makeDraggable(btn, lockKey, action)
    local dragging, dragStart, startPos
    btn.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            if action then action() end
            if not _G[lockKey] and not _G.MasterLock then dragging = true dragStart = input.Position startPos = btn.Position end
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function() dragging = false end)
end

