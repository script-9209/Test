--- ESP SYSTEM (REBUILT) ---
local function applyESP(p)
    local function createESP(char)
        if p == lp then return end
        local h = char:FindFirstChild("ExodusHighlight") or Instance.new("Highlight", char)
        h.Name = "ExodusHighlight"
        h.OutlineTransparency = 0
        
        local head = char:WaitForChild("Head", 10)
        local b = head:FindFirstChild("ExodusTag") or Instance.new("BillboardGui", head)
        b.Name = "ExodusTag"
        b.Size = UDim2.new(0, 100, 0, 50)
        b.AlwaysOnTop = true
        
        local l = b:FindFirstChild("Label") or Instance.new("TextLabel", b)
        l.Name = "Label"
        l.BackgroundTransparency = 1; l.Size = UDim2.new(1, 0, 1, 0); l.Font = Enum.Font.GothamBold; l.TextSize = 14

        task.spawn(function()
            while char.Parent and _G.ESPEnabled do
                local hasK = p.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")
                local hasG = p.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")
                
                h.Enabled = true
                h.FillColor = hasK and Color3.new(1,0,0) or (hasG and Color3.new(0,0,1) or Color3.new(0,1,0))
                l.Text = hasK and "MURDERER" or (hasG and "SHERIFF" or "")
                l.TextColor3 = h.FillColor
                task.wait(1)
            end
            h.Enabled = false
            l.Text = ""
        end)
    end
    p.CharacterAdded:Connect(createESP)
    if p.Character then createESP(p.Character) end
end

Players.PlayerAdded:Connect(applyESP)
for _, p in pairs(Players:GetPlayers()) do applyESP(p) end

--- COMBAT FUNCTIONS ---
local function flingSheriff()
    local s = (function() for _, v in pairs(Players:GetPlayers()) do if v ~= lp and v.Character and (v.Character:FindFirstChild("Gun") or v.Backpack:FindFirstChild("Gun")) then return v end end return nil end)()
    if lp.Character and s and s.Character then
        local hrp = lp.Character.HumanoidRootPart
        local oldCF = hrp.CFrame
        local spin = Instance.new("AngularVelocity", hrp)
        spin.Attachment0 = hrp:FindFirstChild("RootAttachment") or Instance.new("Attachment", hrp)
        spin.MaxTorque = math.huge
        spin.AngularVelocity = Vector3.new(0, 99999, 0)
        hrp.CFrame = s.Character.HumanoidRootPart.CFrame
        task.wait(0.3)
        spin:Destroy()
        hrp.CFrame = oldCF
    end
end

-- Draggable logic
local function makeDraggable(btn, lockKey)
    local dragging, dragStart, startPos
    btn.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and not _G[lockKey] and not _G.LockAll then
            dragging = true dragStart = input.Position startPos = btn.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function() dragging = false end)
end

