--- COMBAT LOGIC ---

local function getMurderer()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and (v.Character:FindFirstChild("Knife") or v.Backpack:FindFirstChild("Knife")) then return v end
    end
    return nil
end

local function getSheriff()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and (v.Character:FindFirstChild("Gun") or v.Backpack:FindFirstChild("Gun")) then return v end
    end
    return nil
end

local function fireGun()
    local gun = lp.Character:FindFirstChild("Gun") or lp.Backpack:FindFirstChild("Gun")
    local m = getMurderer()
    if gun and m and m.Character:FindFirstChild("HumanoidRootPart") then
        if gun.Parent == lp.Backpack then lp.Character.Humanoid:EquipTool(gun) task.wait(0.1) end
        local mHRP = m.Character.HumanoidRootPart
        local originPos = mHRP.Position + Vector3.new(0, 0, 2)
        local targetPos = mHRP.Position + (mHRP.Velocity * 0.15)
        if gun:FindFirstChild("Shoot") then gun.Shoot:FireServer(CFrame.new(originPos, targetPos), CFrame.new(targetPos)) end
    end
end

local function throwKnife()
    local knife = lp.Character:FindFirstChild("Knife") or lp.Backpack:FindFirstChild("Knife")
    local near, dist = nil, math.huge
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local d = (lp.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d near = v end
        end
    end
    if knife and near then
        if knife.Parent == lp.Backpack then lp.Character.Humanoid:EquipTool(knife) end
        local hrp = near.Character.HumanoidRootPart
        knife.Events.KnifeThrown:FireServer({[1] = CFrame.new(hrp.Position + Vector3.new(0,0,1), hrp.Position), [2] = CFrame.new(hrp.Position)})
    end
end

local function flingAction()
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    local s = getSheriff()
    if hrp and s and s.Character and s.Character:FindFirstChild("HumanoidRootPart") then
        local oldCF = hrp.CFrame
        local Velocity = Instance.new("AngularVelocity", hrp)
        Velocity.Attachment0 = hrp:FindFirstChild("RootAttachment") or Instance.new("Attachment", hrp)
        Velocity.MaxTorque = math.huge
        Velocity.AngularVelocity = Vector3.new(0, 99999, 0)
        hrp.CFrame = s.Character.HumanoidRootPart.CFrame
        task.wait(0.3)
        Velocity:Destroy()
        hrp.CFrame = oldCF
    end
end

--- AUTOMATION LOOPS ---

task.spawn(function()
    while task.wait(0.1) do
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        if AutoCollectCoins then
            local cont = workspace:FindFirstChild("Factory") and workspace.Factory:FindFirstChild("CoinContainer")
            if cont then
                local coins = tonumber(lp.PlayerGui.MainGui.Game.Coins.Text:match("%d+")) or 0
                if coins < 40 then
                    for _, c in pairs(cont:GetChildren()) do
                        if c:IsA("BasePart") then hrp.CFrame = c.CFrame task.wait(0.15) end
                        if not AutoCollectCoins or (tonumber(lp.PlayerGui.MainGui.Game.Coins.Text:match("%d+")) or 0) >= 40 then break end
                    end
                end
            end
        end

        if AutoWin then
            local isM = lp.Backpack:FindFirstChild("Knife") or lp.Character:FindFirstChild("Knife")
            local isS = lp.Backpack:FindFirstChild("Gun") or lp.Character:FindFirstChild("Gun")
            if isM then
                for _, v in pairs(Players:GetPlayers()) do
                    if v ~= lp and v.Character and v.Character.Humanoid.Health > 0 then
                        hrp.CFrame = v.Character.HumanoidRootPart.CFrame
                        local k = lp.Character:FindFirstChild("Knife") or lp.Backpack:FindFirstChild("Knife")
                        if k then if k.Parent == lp.Backpack then lp.Character.Humanoid:EquipTool(k) end k.Events.KnifeStabbed:FireServer() end
                        task.wait(0.2)
                    end
                end
            elseif isS then
                local m = getMurderer()
                if m then hrp.CFrame = m.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,3) fireGun() end
            else
                local d = workspace:FindFirstChild("GunDrop", true)
                if d then hrp.CFrame = d.CFrame end
            end
        end
    end
end)

--- ESP SYSTEM ---
local function setupESP(p)
    p.CharacterAdded:Connect(function(char)
        if p == lp then return end
        task.wait(0.5)
        local h = Instance.new("Highlight", char)
        local b = Instance.new("BillboardGui", char:WaitForChild("Head"))
        b.Size = UDim2.new(0, 100, 0, 50); b.AlwaysOnTop = true
        local l = Instance.new("TextLabel", b)
        l.BackgroundTransparency = 1; l.Size = UDim2.new(1, 0, 1, 0); l.Font = Enum.Font.GothamBold; l.TextSize = 14
        task.spawn(function()
            while char.Parent and ESPEnabled do
                local hasK = p.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")
                local hasG = p.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")
                h.FillColor = hasK and Color3.new(1,0,0) or (hasG and Color3.new(0,0,1) or Color3.new(0,1,0))
                l.Text = hasK and "MURDERER" or (hasG and "SHERIFF" or "")
                l.TextColor3 = h.FillColor
                task.wait(1)
            end
            h:Destroy(); b:Destroy()
        end)
    end)
end
for _, p in pairs(Players:GetPlayers()) do setupESP(p) if p.Character then setupESP(p) end end
Players.PlayerAdded:Connect(setupESP)

--- DRAGGABLE SETUP ---
local function makeDraggable(btn, lockKey, action)
    local dragging, dragStart, startPos
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if action then action() end
            if not _G[lockKey] and not _G.LockAll then dragging = true dragStart = input.Position startPos = btn.Position end
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input) dragging = false end)
end

