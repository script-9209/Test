--- TARGET-FRONT-BACK FLY FLING ---
local function flingTarget(target)
    if lp.Character and target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = lp.Character.HumanoidRootPart
        local targetHrp = target.Character.HumanoidRootPart
        local oldCF = hrp.CFrame
        
        local noclip = RunService.Stepped:Connect(function()
            for _, v in pairs(lp.Character:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
        end)
        
        -- Flight/Spin Setup
        local bV = Instance.new("BodyVelocity", hrp)
        bV.Velocity = Vector3.new(0, 0, 0)
        bV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)

        local bA = Instance.new("BodyAngularVelocity", hrp)
        bA.AngularVelocity = Vector3.new(0, 99999, 0)
        bA.MaxTorque = Vector3.new(0, math.huge, 0)

        -- 3s Oscillating Front/Back of Target
        local startTime = tick()
        while tick() - startTime < 3 do
            if not target.Character or not targetHrp.Parent then break end
            -- Rapid front to back of target only
            hrp.CFrame = targetHrp.CFrame * CFrame.new(0, 0, 1.5)
            task.wait(0.03)
            hrp.CFrame = targetHrp.CFrame * CFrame.new(0, 0, -1.5)
            task.wait(0.03)
        end
        
        -- After Fling: Fly stabilization and TP back
        bA.AngularVelocity = Vector3.new(0, 0, 0)
        for i = 1, 3 do
            hrp.Velocity = Vector3.new(0, 0, 0)
            hrp.CFrame = oldCF
            task.wait(1)
        end
        
        -- Cleanup
        bV:Destroy()
        bA:Destroy()
        noclip:Disconnect()
    end
end

--- COMBAT FUNCTIONS ---
local function getMurderer()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and (v.Character:FindFirstChild("Knife") or v.Backpack:FindFirstChild("Knife")) then return v end
    end
    return nil
end

local function getSheriff()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and (v.Character:FindFirstChild("Gun") or v.Backpack:FindFirstChild("Gun")) then return v end
    end
    return nil
end

local function fireGun()
    local gun = lp.Character:FindFirstChild("Gun") or lp.Backpack:FindFirstChild("Gun")
    local m = getMurderer()
    if gun and m and m.Character:FindFirstChild("HumanoidRootPart") then
        if gun.Parent == lp.Backpack then lp.Character.Humanoid:EquipTool(gun) task.wait(0.1) end
        local mHRP = m.Character.HumanoidRootPart
        local origin = mHRP.Position + Vector3.new(0, 0, 1)
        local targetPos = mHRP.Position + (mHRP.Velocity * 0.25)
        local args = {
            [1] = CFrame.new(origin, targetPos) * CFrame.Angles(1.4531978368759155, 0.04432811588048935, 1.6501713991165161), 
            [2] = CFrame.new(targetPos) * CFrame.Angles(-0, 0, -0)
        }
        if gun:FindFirstChild("Shoot") then gun.Shoot:FireServer(unpack(args)) end
    end
end

local function throwAction()
    local knife = lp.Character:FindFirstChild("Knife") or lp.Backpack:FindFirstChild("Knife")
    local near, dist = nil, math.huge
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local d = (lp.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d near = v end
        end
    end
    if knife and near then
        if knife.Parent == lp.Backpack then lp.Character.Humanoid:EquipTool(knife) end
        local args = {
            [1] = CFrame.new(lp.Character.HumanoidRootPart.Position, near.Character.HumanoidRootPart.Position) * CFrame.Angles(1.4531978368759155, 0.04432811588048935, 1.6501713991165161), 
            [2] = CFrame.new(near.Character.HumanoidRootPart.Position) * CFrame.Angles(-0, 0, -0)
        }
        knife.Events.KnifeThrown:FireServer(unpack(args))
    end
end

--- DRAGGABLE LOGIC ---
local function makeDraggable(btn, lockKey, customAction)
    local dragging, dragStart, startPos
    btn.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            if customAction then customAction() end
            if not _G[lockKey] and not _G.LockAll then dragging = true dragStart = input.Position startPos = btn.Position end
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function() dragging = false end)
end

