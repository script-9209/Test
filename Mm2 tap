--- THE ULTRA-SAFE RETURN ---
local function safeReturn(targetCF)
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if hrp and hum then
        hrp.Anchored = true; hum.PlatformStand = true
        hrp.CFrame = targetCF + Vector3.new(0, 5, 0)
        for i = 1, 10 do
            hrp.Velocity = Vector3.zero; hrp.RotVelocity = Vector3.zero
            RunService.Heartbeat:Wait()
        end
        hrp.Anchored = false; hum.PlatformStand = false
    end
end

--- PREDICTIVE WEIGHTED FLING ---
local function ultraFling(target)
    if lp.Character and target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = lp.Character.HumanoidRootPart
        local hum = lp.Character.Humanoid
        local targetHrp = target.Character.HumanoidRootPart
        local oldCF = hrp.CFrame
        
        local bA = Instance.new("BodyAngularVelocity", hrp)
        bA.AngularVelocity = Vector3.new(150, 150, 150)
        bA.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        hum.PlatformStand = true 

        local strike = RunService.Heartbeat:Connect(function()
            if hrp and targetHrp and targetHrp.Parent then
                hrp.Velocity = Vector3.new(25000, 25000, 25000)
                local prediction = targetHrp.Velocity * 0.15
                hrp.CFrame = (targetHrp.CFrame + prediction) * CFrame.new(0, -0.6, 0)
            end
        end)

        task.wait(0.7)
        strike:Disconnect(); bA:Destroy()
        safeReturn(oldCF)
    end
end

--- COMBAT (0-Stud Origin & HRP Target) ---
local function getMurderer()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and (v.Character:FindFirstChild("Knife") or v.Backpack:FindFirstChild("Knife")) then return v end
    end
    return nil
end

local function fireGun()
    local char = lp.Character
    local gun = char and char:FindFirstChild("Gun") or lp.Backpack:FindFirstChild("Gun")
    local m = getMurderer()
    if gun and m and m.Character:FindFirstChild("HumanoidRootPart") then
        if gun.Parent == lp.Backpack then char.Humanoid:EquipTool(gun) task.wait(0.1) end
        local mHRP = m.Character.HumanoidRootPart
        local targetPos = mHRP.Position + (mHRP.Velocity * 0.22)
        -- Spawns bullet at 0 studs from Murderer HRP
        local args = {[1] = CFrame.new(mHRP.Position, targetPos) * CFrame.Angles(1.45, 0, 1.6), [2] = CFrame.new(targetPos)}
        if gun:FindFirstChild("Shoot") then gun.Shoot:FireServer(unpack(args)) end
    end
end

local function throwAction()
    local char = lp.Character
    local knife = char:FindFirstChild("Knife") or lp.Backpack:FindFirstChild("Knife")
    local target, dist = nil, math.huge
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local d = (char.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d target = v end
        end
    end
    if knife and target and target.Character:FindFirstChild("HumanoidRootPart") then
        if knife.Parent == lp.Backpack then char.Humanoid:EquipTool(knife) task.wait(0.1) end
        local tHRP = target.Character.HumanoidRootPart
        -- Spawns knife at 0 studs from Target HRP
        local args = {[1] = CFrame.new(tHRP.Position, tHRP.Position) * CFrame.Angles(1.45, 0, 1.6), [2] = CFrame.new(tHRP.Position)}
        knife.Events.KnifeThrown:FireServer(unpack(args))
    end
end

--- HUD DRAG ---
local function makeDraggable(btn, lockKey, customAction)
    local dragging, dragStart, startPos
    btn.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            if customAction then customAction() end
            if not _G[lockKey] and not _G.LockAll then dragging = true dragStart = input.Position startPos = btn.Position end
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function() dragging = false end)
end

