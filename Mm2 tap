--- NOCLIP LOGIC ---
RunService.Stepped:Connect(function()
    if AutoCollectCoins and lp.Character then
        for _, part in pairs(lp.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    elseif not AutoCollectCoins and lp.Character then
        local hrp = lp.Character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CanCollide = true end
    end
end)

--- LOGIC FUNCTIONS ---
local function getSheriff()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and (v.Character:FindFirstChild("Gun") or v.Backpack:FindFirstChild("Gun")) then return v end
    end
    return nil
end

local function getMurderer()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and (v.Character:FindFirstChild("Knife") or v.Backpack:FindFirstChild("Knife")) then return v end
    end
    return nil
end

local function stab()
    local char = lp.Character
    local knife = char and (char:FindFirstChild("Knife") or lp.Backpack:FindFirstChild("Knife"))
    if knife then
        if knife.Parent == lp.Backpack then lp.Character.Humanoid:EquipTool(knife) end
        knife.Events.KnifeStabbed:FireServer()
    end
end

local function fireGun()
    local char = lp.Character
    local gun = char and (char:FindFirstChild("Gun") or lp.Backpack:FindFirstChild("Gun"))
    local target = getMurderer()
    if gun and target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        if gun.Parent == lp.Backpack then lp.Character.Humanoid:EquipTool(gun) task.wait(0.1) end
        local targetHRP = target.Character.HumanoidRootPart
        local targetPos = targetHRP.Position + (targetHRP.Velocity * PredictionIntensity)
        local direction = (targetPos - Camera.CFrame.Position).Unit
        local originPos = targetPos - (direction * 3) -- ADJUSTED TO 3 STUDS
        if gun:FindFirstChild("Shoot") then
            gun.Shoot:FireServer(CFrame.new(originPos, targetPos), CFrame.new(targetPos))
        end
    end
end

-- Main Loop
task.spawn(function()
    while true do 
        task.wait(0.01)
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        if AutoKillSheriff then
            local target = getSheriff()
            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                hrp.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 1.2); stab()
            end
        end

        if AutoCollectCoins then
            local container = workspace:FindFirstChild("CoinContainer", true)
            if container then
                local coin = container:FindFirstChildWhichIsA("BasePart", true) or container:FindFirstChildWhichIsA("Model", true)
                if coin then
                    hrp.CFrame = coin:IsA("Model") and coin:GetModelCFrame() or coin.CFrame
                    task.wait(_G.TPDelay or 0.5)
                end
            end
        end

        if AutoWin then
            local isMurderer = lp.Backpack:FindFirstChild("Knife") or lp.Character:FindFirstChild("Knife")
            local isSheriff = lp.Backpack:FindFirstChild("Gun") or lp.Character:FindFirstChild("Gun")
            if isMurderer then
                for _, v in pairs(Players:GetPlayers()) do
                    if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character.Humanoid.Health > 0 then
                        hrp.CFrame = v.Character.HumanoidRootPart.CFrame; stab()
                    end
                end
            elseif isSheriff then
                fireGun()
            end
        end
    end
end)

--- ESP (Vibrant Colors) ---
local function setupESP(player)
    local function createESP(char)
        if player == lp then return end
        if char:FindFirstChild("ExodusHighlight") then char.ExodusHighlight:Destroy() end
        if not ESPEnabled then return end
        local head = char:WaitForChild("Head", 5)
        local highlight = Instance.new("Highlight", char); highlight.Name = "ExodusHighlight"
        local bill = Instance.new("BillboardGui", head); bill.Name = "ExodusTag"; bill.Size = UDim2.new(0, 100, 0, 50); bill.StudsOffset = Vector3.new(0, 3, 0); bill.AlwaysOnTop = true
        local label = Instance.new("TextLabel", bill); label.BackgroundTransparency = 1; label.Size = UDim2.new(1, 0, 1, 0); label.Font = Enum.Font.GothamBold; label.TextSize = 14; label.TextStrokeTransparency = 0
        task.spawn(function()
            while char.Parent and ESPEnabled do
                local hasKnife = player.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")
                local hasGun = player.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")
                if hasKnife then 
                    highlight.FillColor = Color3.fromRGB(255, 0, 0); label.TextColor3 = Color3.fromRGB(255, 0, 0); label.Text = "MURDERER"; label.Visible = true
                elseif hasGun then 
                    highlight.FillColor = Color3.fromRGB(0, 150, 255); label.TextColor3 = Color3.fromRGB(0, 150, 255); label.Text = "SHERIFF"; label.Visible = true
                else 
                    highlight.FillColor = Color3.fromRGB(0, 255, 100); label.Visible = false 
                end
                task.wait(1)
            end
            if highlight then highlight:Destroy() end
            if bill then bill:Destroy() end
        end)
    end
    player.CharacterAdded:Connect(createESP)
    if player.Character then createESP(player.Character) end
end

