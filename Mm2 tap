--- SOLID HYBRID FLING (Touch + Spin + Fly | No Noclip) ---
local function ultraFling(target)
    if lp.Character and target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = lp.Character.HumanoidRootPart
        local hum = lp.Character.Humanoid
        local targetHrp = target.Character.HumanoidRootPart
        local oldCF = hrp.CFrame
        
        -- High Torque Spin
        local bA = Instance.new("BodyAngularVelocity", hrp)
        bA.Name = "ExodusSpin"
        bA.AngularVelocity = Vector3.new(0, 999999, 0)
        bA.MaxTorque = Vector3.new(0, math.huge, 0)

        hum.PlatformStand = true 

        -- Strike Connection (Touch + Fly)
        local strikeConnection
        strikeConnection = RunService.Heartbeat:Connect(function()
            if hrp and targetHrp and targetHrp.Parent then
                hrp.Velocity = Vector3.new(95000, 95000, 95000) -- Fly Fling
                local jitter = Vector3.new(math.random(-10, 10)/100, -0.5, math.random(-10, 10)/100)
                hrp.CFrame = targetHrp.CFrame * CFrame.new(jitter) -- Touch Fling
            end
        end)

        task.wait(0.5) 
        
        strikeConnection:Disconnect()
        bA:Destroy()
        
        -- Fly TP Return (2s Stabilized Flight)
        local startReturn = tick()
        while tick() - startReturn < 2 do
            hrp.Velocity = Vector3.zero
            hrp.RotVelocity = Vector3.zero
            hrp.CFrame = oldCF
            task.wait()
        end
        
        hum.PlatformStand = false
    end
end

--- COMBAT FUNCTIONS (0-Stud Origin) ---
local function getMurderer()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and (v.Character:FindFirstChild("Knife") or v.Backpack:FindFirstChild("Knife")) then return v end
    end
    return nil
end

local function getSheriff()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and (v.Character:FindFirstChild("Gun") or v.Backpack:FindFirstChild("Gun")) then return v end
    end
    return nil
end

local function fireGun()
    local char = lp.Character
    local gun = char and char:FindFirstChild("Gun") or lp.Backpack:FindFirstChild("Gun")
    local m = getMurderer()
    
    if gun and m and m.Character:FindFirstChild("HumanoidRootPart") then
        if gun.Parent == lp.Backpack then char.Humanoid:EquipTool(gun) task.wait(0.1) end
        
        local mHRP = m.Character.HumanoidRootPart
        local targetPos = mHRP.Position + (mHRP.Velocity * 0.25) -- Predictive Lead
        
        -- Origin is now exactly on the Murderer (0 studs away)
        local args = {
            [1] = CFrame.new(mHRP.Position, targetPos) * CFrame.Angles(1.45, 0.04, 1.65),
            [2] = CFrame.new(targetPos)
        }
        
        if gun:FindFirstChild("Shoot") then
            gun.Shoot:FireServer(unpack(args))
        end
    end
end

local function throwAction()
    local knife = lp.Character:FindFirstChild("Knife") or lp.Backpack:FindFirstChild("Knife")
    local near, dist = nil, math.huge
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local d = (lp.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d near = v end
        end
    end
    if knife and near and near.Character:FindFirstChild("HumanoidRootPart") then
        if knife.Parent == lp.Backpack then lp.Character.Humanoid:EquipTool(knife) end
        local targetHRP = near.Character.HumanoidRootPart
        local args = {
            [1] = CFrame.new(targetHRP.Position, targetHRP.Position) * CFrame.Angles(1.45, 0.04, 1.65), 
            [2] = CFrame.new(targetHRP.Position)
        }
        knife.Events.KnifeThrown:FireServer(unpack(args))
    end
end

--- HUD DRAG ---
local function makeDraggable(btn, lockKey, customAction)
    local dragging, dragStart, startPos
    btn.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            if customAction then customAction() end
            if not _G[lockKey] and not _G.LockAll then dragging = true dragStart = input.Position startPos = btn.Position end
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function() dragging = false end)
end

makeDraggable(ShootBtn, "ShootLocked", fireGun)
