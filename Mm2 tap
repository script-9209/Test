--- LOGIC FUNCTIONS ---

local function getMurderer()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and (v.Character:FindFirstChild("Knife") or v.Backpack:FindFirstChild("Knife")) then return v end
    end
    return nil
end

local function getSheriff()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and (v.Character:FindFirstChild("Gun") or v.Backpack:FindFirstChild("Gun")) then return v end
    end
    return nil
end

local function getNearestPlayer()
    local nearest, dist = nil, math.huge
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local d = (lp.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d nearest = v end
        end
    end
    return nearest
end

local function stab()
    local knife = lp.Character:FindFirstChild("Knife") or lp.Backpack:FindFirstChild("Knife")
    if knife then
        if knife.Parent == lp.Backpack then lp.Character.Humanoid:EquipTool(knife) end
        knife.Events.KnifeStabbed:FireServer()
    end
end

local function throwKnife()
    local knife = lp.Character:FindFirstChild("Knife") or lp.Backpack:FindFirstChild("Knife")
    local target = getNearestPlayer()
    if knife and target and target.Character:FindFirstChild("HumanoidRootPart") then
        if knife.Parent == lp.Backpack then lp.Character.Humanoid:EquipTool(knife) end
        local targetHRP = target.Character.HumanoidRootPart
        local originCF = CFrame.new(targetHRP.Position + Vector3.new(0, 0, 1), targetHRP.Position)
        local targetCF = CFrame.new(targetHRP.Position)
        knife.Events.KnifeThrown:FireServer({[1] = originCF, [2] = targetCF})
    end
end

local function fireGun()
    local gun = lp.Character:FindFirstChild("Gun") or lp.Backpack:FindFirstChild("Gun")
    local target = getMurderer()
    if gun and target and target.Character:FindFirstChild("HumanoidRootPart") then
        if gun.Parent == lp.Backpack then lp.Character.Humanoid:EquipTool(gun) task.wait(0.1) end
        local targetHRP = target.Character.HumanoidRootPart
        local targetPos = targetHRP.Position + (targetHRP.Velocity * PredictionIntensity)
        if gun:FindFirstChild("Shoot") then
            gun.Shoot:FireServer(CFrame.new(Camera.CFrame.Position, targetPos), CFrame.new(targetPos))
        end
    end
end

-- Main Automation Loop
task.spawn(function()
    while task.wait(0.1) do
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        if AutoKillSheriff then
            local s = getSheriff()
            if s and s.Character:FindFirstChild("HumanoidRootPart") then
                hrp.CFrame = s.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 1.5)
                stab()
            end
        end

        if AutoCollectCoins then
            local container = workspace:FindFirstChild("Factory") and workspace.Factory:FindFirstChild("CoinContainer")
            if container then
                local coinCount = tonumber(lp.PlayerGui.MainGui.Game.Coins.Text:match("%d+")) or 0
                if coinCount >= 40 then
                    local m = getMurderer()
                    if m and m.Character:FindFirstChild("HumanoidRootPart") then
                        hrp.CFrame = m.Character.HumanoidRootPart.CFrame
                        local bV = Instance.new("BodyVelocity", hrp)
                        bV.Velocity = Vector3.new(0, 1000, 0) task.wait(0.1) bV:Destroy()
                    end
                else
                    for _, coin in pairs(container:GetChildren()) do
                        if coin:IsA("BasePart") then hrp.CFrame = coin.CFrame task.wait(0.15) end
                        if not AutoCollectCoins or tonumber(lp.PlayerGui.MainGui.Game.Coins.Text:match("%d+")) >= 40 then break end
                    end
                end
            end
        end

        if AutoWin then
            local isM = lp.Backpack:FindFirstChild("Knife") or lp.Character:FindFirstChild("Knife")
            local isS = lp.Backpack:FindFirstChild("Gun") or lp.Character:FindFirstChild("Gun")
            if isM then
                for _, v in pairs(Players:GetPlayers()) do
                    if v ~= lp and v.Character and v.Character.Humanoid.Health > 0 then
                        hrp.CFrame = v.Character.HumanoidRootPart.CFrame; stab(); task.wait(0.2)
                    end
                end
            elseif isS then
                local m = getMurderer()
                if m then hrp.CFrame = m.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,3); fireGun() end
            else
                local drop = workspace:FindFirstChild("GunDrop", true)
                if drop then hrp.CFrame = drop.CFrame else
                    local lobby = workspace:FindFirstChild("Lobby")
                    if lobby then hrp.CFrame = lobby.CFrame + Vector3.new(0,5,0) end
                end
            end
        end
    end
end)

-- Draggable Logic
local function makeDraggable(btn, lockKey, action)
    local dragging, dragStart, startPos
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if action then action() end
            if not _G[lockKey] then dragging = true dragStart = input.Position startPos = btn.Position end
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input) dragging = false end)
end

makeDraggable(ShootButton, "ShootLocked", fireGun)
makeDraggable(ThrowButton, "ThrowLocked", throwKnife)
makeDraggable(GunButton, "GunLocked", function()
    local drop = workspace:FindFirstChild("GunDrop", true)
    if drop and lp.Character:FindFirstChild("HumanoidRootPart") then
        local old = lp.Character.HumanoidRootPart.CFrame
        lp.Character.HumanoidRootPart.CFrame = drop.CFrame task.wait(0.1)
        lp.Character.HumanoidRootPart.CFrame = old
    end
end)

-- ESP SYSTEM
local function setupESP(player)
    local function createESP(char)
        if player == lp then return end
        local head = char:WaitForChild("Head", 15)
        if not head or not ESPEnabled then return end
        local highlight = Instance.new("Highlight", char)
        highlight.Name = "ExodusHighlight"
        local bill = Instance.new("BillboardGui", head)
        bill.Name = "ExodusTag"
        bill.Size = UDim2.new(0, 100, 0, 50)
        bill.AlwaysOnTop = true
        local label = Instance.new("TextLabel", bill)
        label.BackgroundTransparency = 1; label.Size = UDim2.new(1, 0, 1, 0); label.Font = Enum.Font.GothamBold; label.TextSize = 14
        task.spawn(function()
            while char.Parent and ESPEnabled do
                local hasK = player.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")
                local hasG = player.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")
                highlight.FillColor = hasK and Color3.new(1,0,0) or (hasG and Color3.new(0,0,1) or Color3.new(0,1,0))
                label.Text = hasK and "MURDERER" or (hasG and "SHERIFF" or "INNOCENT")
                label.TextColor3 = highlight.FillColor; task.wait(1)
            end
            highlight:Destroy(); bill:Destroy()
        end)
    end
    player.CharacterAdded:Connect(createESP)
    if player.Character then createESP(player.Character) end
end
for _, p in pairs(Players:GetPlayers()) do setupESP(p) end
Players.PlayerAdded:Connect(setupESP)

